{
  "name": "terracare-messenger",
  "version": "1.0.0",
  "description": "Secure Communication Layer for TerraCare - Privacy-First Messaging",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm start",
    "build": "cd client && npm run build",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "terracare",
    "messenger",
    "encryption",
    "webrtc",
    "e2e",
    "privacy",
    "secure-messaging"
  ],
  "author": "TerraCare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DudeAdrian/terracare-messenger.git"
  },
  "bugs": {
    "url": "https://github.com/DudeAdrian/terracare-messenger/issues"
  },
  "homepage": "https://github.com/DudeAdrian/terracare-messenger#readme",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "socket.io": "^4.7.2",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
