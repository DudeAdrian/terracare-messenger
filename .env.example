# Server Configuration
PORT=3008
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# MongoDB (Optional - for message persistence)
MONGODB_URI=mongodb://localhost:27017/terracare_messenger

# WebRTC Configuration
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=turn:your-turn-server.com
TURN_USERNAME=username
TURN_PASSWORD=password

# TerraCare Integration
TERRACARE_RPC_URL=http://localhost:8545
IDENTITY_REGISTRY_ADDRESS=0x...
TOKEN_ENGINE_ADDRESS=0x...

# WalletConnect
WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id
